{
  "dashboard": {
  "id": null,
  "title": "miniAI — LLM platform on a Mac mini",
  "uid": "miniAI",
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Requests / min by status",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(gateway_requests_total[5m]) * 60", "legendFormat": "{{status}}" }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Latency p50 / p95 (s)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(gateway_request_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(gateway_request_latency_seconds_bucket[5m]))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Tokens generated / sec",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [{ "expr": "rate(gateway_tokens_generated_total[1m])", "legendFormat": "tok/s" }]
    },
    {
      "id": 4, "type": "stat", "title": "Queue depth",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [{ "expr": "gateway_queue_depth" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "orange", "value": 4 }, { "color": "red", "value": 7 }
      ] } }, "overrides": [] }
    },
    {
      "id": 5, "type": "timeseries", "title": "Agent tool calls / min",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [{ "expr": "rate(gateway_tool_calls_total[5m]) * 60", "legendFormat": "{{tool}}" }]
    }
  ],
  "schemaVersion": 39,
  "version": 0
  },
  "folderUid": "",
  "overwrite": true
}

; Grafana runs locally on the Mac mini, but browsers reach it through the
; HTTPS nginx reverse proxy on the EC2 bastion.
[paths]
; Homebrew's service does not infer this from the custom config file. Keep the
; provisioning location explicit so datasource/dashboard files installed by
; Ansible are actually scanned at Grafana startup.
provisioning = {{ brew_prefix.stdout }}/etc/grafana/provisioning

[server]
domain = grafana.mini-agent.dev
root_url = https://grafana.mini-agent.dev/
serve_from_sub_path = false

; This is an intentional public portfolio dashboard. Viewers can inspect the
; provisioned dashboard but cannot edit it or administer Grafana.
[auth.anonymous]
enabled = true
org_role = Viewer

[security]
cookie_secure = true
